# Supabase — copy to .env.local and fill in from your project's API settings.
# Project Settings → API → Project URL and anon/public key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings → API). Server-only — never expose to the client.
# Used by the Stripe webhook to record donations.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Developers → API keys, and Developers → Webhooks for the signing secret).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public base URL used for Stripe redirect URLs (e.g. https://your-domain.com).
# Optional locally; falls back to the request origin.
NEXT_PUBLIC_SITE_URL=
